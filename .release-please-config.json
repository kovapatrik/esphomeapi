{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "crates/esphomeapi-manager-node": {
      "release-type": "node",
      "package-name": "@kovapatrik/esphomeapi-manager",
      "include-component-in-tag": false,
      "tag-name": "v${version}",
      "extra-files": [
        {
          "type": "generic",
          "path": "crates/esphomeapi-manager-node/index.js",
          "patterns": [
            "bindingPackageVersion !== '(?<version>[0-9]+\\.[0-9]+\\.[0-9]+)'",
            "expected (?<version>[0-9]+\\.[0-9]+\\.[0-9]+) but got"
          ]
        }
      ]
    }
  }
}
